# Copy this file to .env (gitignored) in the repo root, next to server.js.
# Format: one KEY=value per line. Full-line comments like this one are ignored.
# WARNING: do NOT put comments after a value on the same line — the loader
# keeps everything after "=" as the value, so "KEY=abc  # note" breaks the key.
# Real environment variables win over this file.

# Novita — novita.ai console -> Settings -> Key Management (key starts with sk_)
NOVITA_API_KEY=sk_paste_yours_here
# Verify the exact model id with:
#   curl -s https://api.novita.ai/openai/v1/models -H "Authorization: Bearer $NOVITA_API_KEY"
NOVITA_MODEL=deepseek/deepseek-v4-flash

# ActionLayer — actionlayer.io/app -> Settings (key starts with ak_)
ACTIONLAYER_API_KEY=ak_paste_yours_here
ACTIONLAYER_API_URL=https://api.actionlayer.io

# Cloudflare Worker — filled in after workstream A deploys it
WORKER_URL=
INGEST_SECRET=
ATTEST_SECRET=

# Twilio — only if you do the ~$20 upgrade; leave empty to use the PRERUN voice path
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

PORT=8080
